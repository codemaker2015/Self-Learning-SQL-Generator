# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_CHAT_DEPLOYMENT=gpt-4.1
AZURE_EMBED_DEPLOYMENT=text-embedding-ada-002

# Feedback store (pgvector enabled PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sqlassistant

# Target database users will query against
TARGET_DATABASE_URL=postgresql://postgres:password@localhost:5432/your_target_db
